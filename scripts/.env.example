# Configuración para los scripts de ingesta.
# Copiá este archivo como .env y completá. El .env está en .gitignore.

# === WordPress (mariovadillo.com.ar) ===
# Cargado por scripts/ingest-vadillo-wordpress.py
WP_BASE_URL=https://mariovadillo.com.ar
WP_USER=vadilloedit
WP_APP_PASSWORD=AQUI_TU_APP_PASSWORD_CON_ESPACIOS

# Categorías a ingestar (slugs separados por coma).
# Vacío = todas. Slugs típicos del sitio (sección /guia/):
#   autoplanes, bancos, danos, datos-personales, educacion,
#   garantias, locaciones-alquileres, multas, salud, seguros,
#   servicios-publicos, turismo
WP_CATEGORY_SLUGS=autoplanes,bancos,danos,datos-personales,educacion,garantias,locaciones-alquileres,multas,salud,seguros,servicios-publicos,turismo

# === MDZ (mdzol.com/consumidores) ===
# El script ingest-mdz-articles.py no necesita auth — toma flags por CLI.
# Si tenés acceso a Disqus o un sistema de autor, agregar variables acá.
